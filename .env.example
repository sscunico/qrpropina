APP_URL="http://localhost:3000"
APP_NAME="qrpropina"
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"
ADMIN_GOOGLE_EMAILS="sscunico@gmail.com"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Leave true to test the local UI without calling Mercado Pago.
# Set false only when using TEST credentials for an integration test.
MP_ENABLE_DEMO_CHECKOUT="true"
PLATFORM_COMMISSION_PERCENT="5"

# Mercado Pago production/test credentials.
# For marketplace mode, each creator should connect their Mercado Pago account via OAuth.
# Use TEST-... for integration tests.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""
# Secret generated in Mercado Pago Developers > Your integration > Webhooks.
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_AUTH_BASE_URL="https://auth.mercadopago.com.ar"
MERCADOPAGO_API_BASE_URL="https://api.mercadopago.com"
MERCADOLIBRE_API_BASE_URL="https://api.mercadolibre.com"
MERCADOPAGO_USE_SANDBOX_LINK="true"

# Used to encrypt connected seller tokens in the DB.
# Put any long random string here before using real OAuth.
APP_ENCRYPTION_KEY="change-me-before-production"
